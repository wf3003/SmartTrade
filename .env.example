# ═══════════════════════════════════════════════════════════════
#  SmartTrade — AI 多交易所合约交易系统
#  使用前请填写下方各交易所 API 密钥
# ═══════════════════════════════════════════════════════════════



# ═══════════════════════════
#  一、交易所配置
# ═══════════════════════════

# 启用哪些交易所（逗号分隔）
# 可选: okx, gate, binance
EXCHANGES=okx

# ─── OKX ───
# OKX API 密钥（在 okx.com → API → 创建交割合约API）
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_API_PASSPHRASE=your_okx_passphrase
# 启用模拟盘（建议先跑模拟盘测试）
# true  = 测试网（零风险，推荐首次使用）
# false = 实盘（真金白银，请先测试）
OKX_SANDBOX=true

# ─── Gate.io ───
# Gate.io API 密钥（在 gate.io → 账户 → API管理 → 创建API Key）
GATE_API_KEY=your_gate_api_key
GATE_API_SECRET=your_gate_api_secret
GATE_SANDBOX=false

# ─── Binance ───
# 币安 API 密钥（在 binance.com → API管理 → 创建API Key）
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
# Binance 官方测试网: https://testnet.binancefuture.com/
BINANCE_SANDBOX=true



# ═══════════════════════════
#  二、AI 模型配置
# ═══════════════════════════

# AI 供应商（deepseek / openai / openrouter）
AI_PROVIDER=deepseek
# API 密钥（在供应商官网获取）
AI_API_KEY=your_deepseek_api_key
# API 地址
# DeepSeek:   https://api.deepseek.com/v1
# OpenAI:     https://api.openai.com/v1
# OpenRouter: https://openrouter.ai/api/v1
AI_BASE_URL=https://api.deepseek.com/v1
# 模型名
# DeepSeek:   deepseek-v4-flash / deepseek-v4-pro
# OpenAI:     gpt-4o / o1-mini
# OpenRouter: 任意支持的模型
AI_MODEL=deepseek-v4-pro
# 创造性（0.0 = 保守稳定，1.0 = 自由激进）
# 交易推荐: 0.2 ~ 0.5
AI_TEMPERATURE=0.2
# AI 单次决策最大 token 数
AI_MAX_TOKENS=8000



# ═══════════════════════════
#  三、交易核心参数
# ═══════════════════════════

# 交易模式
# swap = 合约/U本位永续（推荐）
# spot = 现货
TRADE_MODE=swap

# 默认杠杆倍数（AI 可在此之上灵活调整）
DEFAULT_LEVERAGE=8
# 允许的最大杠杆倍数
MAX_LEVERAGE=25

# 最大同时持仓数
MAX_POSITIONS=20
# 单笔持仓最长持有时间（小时，超时 AI 会被要求评估平仓）
MAX_HOLDING_HOURS=36

# 初始资金（仅用于计算盈亏比例，不影响实际交易）
INITIAL_BALANCE=10000

# 交易币种列表（逗号分隔，格式: BTC/USDT）
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT,BNB/USDT,SUI/USDT,LINK/USDT,AAVE/USDT



# ═══════════════════════════
#  四、风控设置
# ═══════════════════════════

# 账户止损线（总权益低于此值时，停止开新仓）
ACCOUNT_STOP_LOSS_USDT=500
# 账户止盈线（总权益达到此值时，停止开新仓，落袋为安）
ACCOUNT_TAKE_PROFIT_USDT=20000
# 最大回撤比例（账户总权益从峰值下跌 % 时，AI 被限制开新仓）
MAX_DRAWDOWN_PERCENT=20
# 单日最大亏损（当天累计亏损超过此值，暂停一切交易）
DAILY_LOSS_LIMIT_USDT=200

# ─── 分批止盈 + 跟踪止盈（代码级自动保护） ───
# 逐步锁定利润，防止坐过山车
# stage1: 盈利 10% 时 → 平30%仓位（锁定部分利润）
PARTIAL_TP_STAGE1_TRIGGER=10
PARTIAL_TP_STAGE1_CLOSE=30
# 第2/3阶段关闭，改为跟踪止盈：剩余仓位从峰值回撤5%自动平仓
PARTIAL_TP_STAGE2_TRIGGER=999
PARTIAL_TP_STAGE2_CLOSE=30
PARTIAL_TP_STAGE3_TRIGGER=999
PARTIAL_TP_STAGE3_CLOSE=30



# ═══════════════════════════
#  五、服务配置
# ═══════════════════════════

# Web 仪表盘端口
PORT=3100
# 监听地址
# 0.0.0.0 = 允许局域网访问
# 127.0.0.1 = 仅本机访问
HOST=0.0.0.0



# ═══════════════════════════
#  六、数据与日志
# ═══════════════════════════

# SQLite 数据库路径（自动在 data/ 目录创建）
DATABASE_URL=file:./data/quantmax.db
# 日志级别: info / warn / error / debug
LOG_LEVEL=info


# ═══════════════════════════
#  七、代理设置（可选）
# ═══════════════════════════

# 通过 Clash / V2Ray 等代理访问交易所 API
# HTTPS_PROXY=http://127.0.0.1:7890
# 不走代理的地址（DeepSeek API 直连、本地地址）
# NO_PROXY=api.deepseek.com,localhost,127.0.0.1
