# ═══════════════════════════════════════════════════════════════
#  SmartTrade — AI 多交易所合约交易系统
#  使用前请填写下方各交易所 API 密钥
# ═══════════════════════════════════════════════════════════════



# ═══════════════════════════
#  一、交易所配置
# ═══════════════════════════

# 启用哪些交易所（逗号分隔）
# 可选: okx, gate, binance
EXCHANGES=okx

# ─── OKX ───
# OKX API 密钥（在 okx.com → API → 创建交割合约API）
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_API_PASSPHRASE=your_okx_passphrase
# 启用模拟盘（建议先跑模拟盘测试）
# true  = 测试网（零风险，推荐首次使用）
# false = 实盘（真金白银，请先测试）
OKX_SANDBOX=true

# ─── Gate.io ───
GATE_API_KEY=your_gate_api_key
GATE_API_SECRET=your_gate_api_secret
GATE_SANDBOX=false

# ─── Binance ───
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_SANDBOX=true



# ═══════════════════════════
#  二、AI 模型配置
# ═══════════════════════════

AI_API_KEY=your_deepseek_api_key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-v4-pro
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=3000



# ═══════════════════════════
#  三、交易核心参数
# ═══════════════════════════

TRADE_MODE=swap

# 默认杠杆基数（策略根据行情按比例调整）
# 强趋势: ×1.0 弱趋势: ×0.7 震荡: ×0.4
DEFAULT_LEVERAGE=6
# 允许的最大杠杆倍数
MAX_LEVERAGE=25

# 最大同时持仓数
MAX_POSITIONS=20
# 单笔持仓最长持有时间（小时）
MAX_HOLDING_HOURS=36

# 每笔开仓占可用资金百分比（行情好时满仓，差时自动缩到 60%/40%）
BASE_POSITION_PCT=5

# 初始资金（仅用于计算盈亏比例）
INITIAL_BALANCE=6000

# 交易币种列表
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT,BNB/USDT,SUI/USDT,LINK/USDT,AAVE/USDT



# ═══════════════════════════
#  四、风控设置
# ═══════════════════════════

# 账户止损线（总权益低于此值时，停止开新仓）
ACCOUNT_STOP_LOSS_USDT=500
# 账户止盈线
ACCOUNT_TAKE_PROFIT_USDT=20000
# 最大回撤比例
MAX_DRAWDOWN_PERCENT=20
# 单日最大亏损
DAILY_LOSS_LIMIT_USDT=200



# ═══════════════════════════
#  五、服务配置
# ═══════════════════════════

PORT=3100
HOST=0.0.0.0



# ═══════════════════════════
#  六、数据与日志
# ═══════════════════════════

DATABASE_URL=file:./data/quantmax.db
LOG_LEVEL=info


# ═══════════════════════════
#  七、代理设置（可选）
# ═══════════════════════════

# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=api.deepseek.com,localhost,127.0.0.1